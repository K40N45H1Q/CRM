<script setup>
import { ref, defineProps, defineEmits, onMounted, onBeforeUnmount } from 'vue'

const props = defineProps({
  options: Array,
  modelValue: [String, Number, Object]
})

const emit = defineEmits(['update:modelValue'])

const open = ref(false)
const root = ref(null)

const toggle = () => (open.value = !open.value)
const select = (o) => (emit('update:modelValue', o), open.value = false)

const label = () =>
  props.modelValue == null
    ? 'Выберите вариант'
    : typeof props.modelValue === 'object'
      ? props.modelValue.label
      : props.modelValue

const outside = (e) => !root.value?.contains(e.target) && (open.value = false)

onMounted(() => document.addEventListener('click', outside))
onBeforeUnmount(() => document.removeEventListener('click', outside))
</script>

<template>
  <div class="dropdown" ref="root">
    <button @click="toggle" class="bordered dropdown-button">
      {{ label() }}
      <span class="arrow" :class="{ open }">▼</span>
    </button>

    <ul class="dropdown-menu" :class="{ open }">
      <li
        v-for="(o, i) in props.options"
        :key="i"
        @click="select(o)"
        :class="{ selected: o === props.modelValue }"
      >
        {{ typeof o === 'object' ? o.label : o }}
      </li>
    </ul>
  </div>
</template>

<style scoped>
